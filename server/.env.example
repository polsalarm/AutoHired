# AutoHired server configuration
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# AI provider — leave all unset to use the offline heuristic fallback.
# Priority: Vertex → Gemini API key → Anthropic. Pick one.

# Vertex AI (Gemini — uses your GCP credits, unlocks gemini-2.5-pro)
VERTEX_PROJECT=
VERTEX_LOCATION=global
VERTEX_MODEL=gemini-2.5-pro
# Vertex auth, pick one:
#  LOCAL  → run `gcloud auth application-default login` (ADC; nothing to set here,
#           or point GOOGLE_APPLICATION_CREDENTIALS at the file if non-default)
#  PROD   → paste the service-account JSON key as a single-line string below
#           (Vercel/Render have no gcloud). Takes precedence over ADC.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_KEY=

# Google Gemini (AI Studio — has a FREE tier; key at aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Anthropic Claude (paid — prepaid credits at console.anthropic.com)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Supabase (service role used server-side only — never expose to client)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
