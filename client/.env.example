# Supabase — client-side (anon key is safe to expose; RLS enforces access)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# API server origin. Leave EMPTY for local dev (Vite proxies /api → localhost:3001).
# In production set to the deployed server URL, e.g. https://autohired-api.onrender.com
VITE_API_URL=

# Gmail interview-email sync (optional). A Google Cloud OAuth 2.0 *Web* client ID.
# Enables the "Sync Gmail" button on the Schedule page; leave empty to hide it.
# The gmail.readonly scope is restricted — while unverified, add yourself as a
# test user under the OAuth consent screen's "Testing" mode (no review needed).
VITE_GOOGLE_CLIENT_ID=
